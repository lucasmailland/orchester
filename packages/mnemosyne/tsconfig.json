{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    // composite is intentionally OFF: with the integration tests pulling
    // shared apps/web testcontainer fixtures (which transitively reach
    // every `packages/db/src/schema/*.ts`), composite would require us
    // to enumerate every transitive .ts file in `include`. Mnemosyne is
    // not consumed via project references anywhere yet, so dropping it
    // costs nothing and lets `tsc --noEmit` walk imports normally.
    //
    // rootDir = monorepo root: canonical fix for a package that
    // legitimately consumes from siblings (apps/web test fixtures +
    // packages/db schema). Explicitly setting it tells TS the
    // compilation graph spans the monorepo, so it stops rejecting
    // cross-package files as out-of-tree. Under `--noEmit` no output
    // is written; rootDir's only remaining effect is the boundary
    // check — and a monorepo-wide boundary is what we want here.
    //
    // baseUrl is deprecated in TS 6.0 (removed in 7.0). Keeping it
    // because dropping it changes how `paths` resolves on some
    // toolchains (drizzle-kit still consults it as of this commit).
    // `ignoreDeprecations: "6.0"` silences the deprecation error at
    // the current TS version. Post-v1.0 polish: extract fixtures to
    // a shared package, then drop baseUrl + ignoreDeprecations.
    "rootDir": "../..",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@orchester/db": ["../db/src/index.ts"],
      "@orchester/db/schema": ["../db/src/schema/index.ts"]
    }
  },
  "include": ["src/**/*", "tests/**/*"]
}
