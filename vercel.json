{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter @orchester/db push --force && pnpm --filter web build",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": "nextjs",
  "outputDirectory": "apps/web/.next",
  "regions": ["iad1"],
  "functions": {
    "apps/web/app/api/flows/[id]/run/route.ts": { "maxDuration": 300 },
    "apps/web/app/api/agents/[id]/test-chat/route.ts": { "maxDuration": 60 },
    "apps/web/app/api/agents/[id]/generate-prompt/route.ts": { "maxDuration": 60 },
    "apps/web/app/api/widget/[channelId]/messages/route.ts": { "maxDuration": 60 },
    "apps/web/app/api/channels/telegram/webhook/[secret]/route.ts": { "maxDuration": 60 },
    "apps/web/app/api/webhooks/[secret]/route.ts": { "maxDuration": 300 },
    "apps/web/app/api/knowledge-bases/[id]/docs/route.ts": { "maxDuration": 300 },
    "apps/web/app/api/knowledge-bases/[id]/search/route.ts": { "maxDuration": 30 },
    "apps/web/app/api/billing/webhook/route.ts": { "maxDuration": 30 }
  },
  "crons": [],
  "headers": [
    {
      "source": "/api/embed",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=300" }
      ]
    },
    {
      "source": "/api/widget/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
